{
    "dev": {
        "app_function": "sanji.service.lambda_app.app",
        "aws_region": "<AWS_REGION>",
        "log_level": "WARNING",
        "project_name": "sanji-api",
        "runtime": "python3.14",
        "s3_bucket": "sanji-api-zappa-<AWS_ACCOUNT_ID>-<REGION_SHORT>",
        "keep_warm": false,
        "timeout_seconds": 30,
        "memory_size": 256,
        "environment_variables": {
            "LOG_LEVEL": "INFO",
            "SANJI_ENVIRONMENT": "dev",
            "SECRET_KEY": "<GENERATE_LONG_RANDOM_SECRET>",
            "AWS_ACCOUNT_ID": "<AWS_ACCOUNT_ID>",
            "DYNAMODB_PROCESSINGJOB_REQUESTS_TABLENAME": "sanji-jobs-requests-dev",
            "DYNAMODB_PROCESSINGJOB_SETTINGS_TABLENAME": "sanji-jobs-settings-dev",
            "DYNAMODB_SORTINDEX_INDEXNAME": "sanji-jobs-sortindex-dev",
            "PROCESSINGJOB_REQUEST_QUEUE_URL": "https://sqs.<AWS_REGION>.amazonaws.com/<AWS_ACCOUNT_ID>/sanji-sdjobs-eph-dev",
            "STRIPE_SECRET_KEY": "sk_test_<YOUR_STRIPE_SECRET_KEY>",
            "STRIPE_WEBHOOK_SECRET": "whsec_<YOUR_STRIPE_WEBHOOK_SECRET>",
            "STRIPE_PUBLISHABLE_KEY": "pk_test_<YOUR_STRIPE_PUBLISHABLE_KEY>",
            "SANJI_STRIPE_PRICE_PRO": "price_<YOUR_PRO_PRICE_ID>",
            "SANJI_STRIPE_PRICE_BUSINESS": "price_<YOUR_BUSINESS_PRICE_ID>",
            "SANJI_SUBSCRIPTIONS_TABLE": "sanji-subscriptions-dev",
            "SANJI_WEBHOOK_EVENTS_TABLE": "sanji-webhook-events-dev",
            "SANJI_RESULTS_BUCKET": "<SANJI_RESULTS_BUCKET>",
            "SANJI_UPLOADS_BUCKET": "<SANJI_UPLOADS_BUCKET>"
        },
        "exclude": [
            ".git",
            ".venv",
            "__pycache__",
            "*.pyc",
            "tests",
            "test-reports",
            ".idea",
            ".github",
            "*.md",
            "*.egg-info",
            "data/bench",
            "*.mp4",
            "*.wav"
        ]
    }
}
